# ===================
# Required Configuration
# ===================

# Telegram Bot Token
# Get from @BotFather: https://t.me/BotFather
TELEGRAM_BOT_TOKEN=

# Auth Server Base URL (REQUIRED for production)
# Must be a publicly accessible HTTPS URL
# For development, use ngrok: ngrok http 9876
AUTH_BASE_URL=

# ===================
# Optional Configuration
# ===================

# Anuma API URL (default: https://portal.anuma-dev.ai)
# ANUMA_API_URL=https://portal.anuma-dev.ai

# Privy App ID (uses built-in app if not set)
# Get from: https://dashboard.privy.io
# PRIVY_APP_ID=

# Auth server port (default: 9876)
# AUTH_PORT=9876
